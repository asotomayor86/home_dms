# ─────────────────────────────────────────────────────────────
# Base de datos (PostgreSQL — Vercel Postgres / Neon)
# DATABASE_URL: cadena con pooling (en Vercel = POSTGRES_PRISMA_URL)
# DIRECT_URL:   cadena directa, sin pooling, para migraciones
#               (en Vercel = POSTGRES_URL_NON_POOLING)
# En local puedes poner el mismo valor en ambas.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# Genera un secreto con:  npx auth secret   (o)  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="genera-un-secreto-aleatorio"

# ─────────────────────────────────────────────────────────────
# Seed del administrador inicial (opcional; si no, se usan las
# constantes marcadas en prisma/seed.ts)
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="cambia-esto-1234"
SEED_ADMIN_DISPLAYNAME="Administrador"
