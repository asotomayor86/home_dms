# ─────────────────────────────────────────────────────────────
# Base de datos (PostgreSQL — Vercel Postgres / Neon)
# Se usan los nombres que crea la integración Neon ↔ Vercel:
#   POSTGRES_PRISMA_URL      → con pooling (runtime serverless)
#   POSTGRES_URL_NON_POOLING → directa, para migraciones
# En Vercel las inyecta la integración automáticamente (no las pongas a mano).
# En local puedes poner el mismo valor en ambas.
# ─────────────────────────────────────────────────────────────
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# Genera un secreto con:  npx auth secret   (o)  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="genera-un-secreto-aleatorio"

# ─────────────────────────────────────────────────────────────
# Seed del administrador inicial (opcional; si no, se usan las
# constantes marcadas en prisma/seed.ts)
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="cambia-esto-1234"
SEED_ADMIN_DISPLAYNAME="Administrador"
