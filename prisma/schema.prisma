// Prisma schema — HOME DMS
// Incremento 1: gestión de usuarios (sims), hogares y pertenencias.
// Incremento 2: catálogo de recetas (Recipe, Ingredient, RecipeIngredient)
//               y selección de recetas por hogar (HouseholdRecipe).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Nombres de variable que crea la integración Neon ↔ Vercel:
  //   POSTGRES_PRISMA_URL      → conexión con pooling (runtime serverless)
  //   POSTGRES_URL_NON_POOLING → conexión directa (migraciones)
  // En local apunta ambas a tu cadena de conexión (ver .env.example).
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum GlobalRole {
  ADMIN
  USER
}

/// Un "sim" es una cuenta de persona dentro de la app (no hay email en ningún sitio).
model Sim {
  id                 String       @id @default(cuid())
  username           String       @unique
  passwordHash       String
  displayName        String
  avatar             String?
  globalRole         GlobalRole   @default(USER)
  mustChangePassword Boolean      @default(true)
  createdAt          DateTime     @default(now())

  memberships        Membership[]
  createdRecipes     Recipe[]      @relation("RecipeCreatedBy")
  plannedMeals       PlannedMeal[] @relation("PlannedMealCreatedBy")
}

/// Un hogar al que pertenecen uno o varios sims.
model Household {
  id          String            @id @default(cuid())
  name        String
  createdAt   DateTime          @default(now())

  memberships  Membership[]
  recipes      HouseholdRecipe[]
  plannedMeals PlannedMeal[]
}

/// Relación N:M entre Sim y Household. Sin rol dentro del hogar.
model Membership {
  simId       String
  householdId String
  joinedAt    DateTime  @default(now())

  sim         Sim       @relation(fields: [simId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@id([simId, householdId])
}

// ─────────────────────────────────────────────────────────────────────────
// Incremento 2 — Recetas
// ─────────────────────────────────────────────────────────────────────────

/// Unidad de medida de un ingrediente. AL_GUSTO no se escala en la cesta.
enum Unit {
  GRAMO
  KILOGRAMO
  MILILITRO
  LITRO
  UNIDAD
  CUCHARADA
  CUCHARADITA
  PIZCA
  DIENTE
  LATA
  MANOJO
  AL_GUSTO
}

/// Categoría del ingrediente; sirve para agrupar la futura cesta por secciones.
enum IngredientCategory {
  VERDURA
  FRUTA
  CARNE
  PESCADO
  LACTEO
  HUEVOS
  PANADERIA
  DESPENSA
  CONGELADO
  BEBIDA
  CONDIMENTO
  OTRO
}

/// Catálogo maestro de ingredientes (normalizado, para poder agregar la cesta).
model Ingredient {
  id          String             @id @default(cuid())
  name        String             @unique
  category    IngredientCategory @default(OTRO)
  defaultUnit Unit               @default(UNIDAD)

  // Nutrición por 100 g (opcional; "no informado" = se excluye del cálculo de receta).
  kcalPer100    Float?
  proteinPer100 Float?
  carbsPer100   Float?
  fatPer100     Float?
  fiberPer100   Float?
  sugarPer100   Float?
  saltPer100    Float?

  // Gramos que pesa 1 "unidad base" (para UNIDAD/DIENTE/LATA/MANOJO/cucharadas…).
  gramsPerUnit Float?
  // Código del producto de Open Food Facts del que se tomaron los valores.
  offId        String?

  recipeIngredients RecipeIngredient[]
}

/// Una receta = un plato. El catálogo es global (visible para todos los hogares);
/// cada hogar elige cuáles usa en sus planes vía HouseholdRecipe.
model Recipe {
  id               String   @id @default(cuid())
  name             String
  description      String?
  steps            String[] // pasos del proceso, en orden
  imageUrl         String?
  servings         Int      @default(2) // raciones base de las cantidades
  prepMinutes      Int?
  suitableForLunch Boolean  @default(true)
  suitableForDinner Boolean @default(true)
  isActive         Boolean  @default(true)

  // Valores nutricionales estimados POR RACIÓN (opcionales).
  calories      Float? // kcal
  protein       Float? // g
  carbs         Float? // g
  fat           Float? // g
  fiber         Float? // g
  sugar         Float? // g
  salt          Float? // g

  createdById      String?
  createdAt        DateTime @default(now())

  // Si se borra el autor, la receta permanece en el catálogo común (createdById → null).
  createdBy    Sim?               @relation("RecipeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  ingredients  RecipeIngredient[]
  households   HouseholdRecipe[]
  plannedMeals PlannedMeal[]
}

/// Relación receta ↔ ingrediente con la cantidad para las `servings` base.
model RecipeIngredient {
  recipeId     String
  ingredientId String
  quantity     Float
  unit         Unit
  note         String?

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([recipeId, ingredientId])
}

/// Recetas que un hogar ha seleccionado ("estrella") para entrar en su plan.
/// Es el "pool" disponible para asignar en el calendario y para el futuro draft.
model HouseholdRecipe {
  householdId String
  recipeId    String
  addedAt     DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipe    Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([householdId, recipeId])
}

// ─────────────────────────────────────────────────────────────────────────
// Incremento 3 — Calendario de menús
// ─────────────────────────────────────────────────────────────────────────

/// Hueco de comida del día.
enum MealSlot {
  LUNCH
  DINNER
}

/// Una receta asignada a un hueco (comida/cena) de un día concreto en un hogar.
/// La clave única (householdId, date, slot) garantiza un único plato por hueco.
model PlannedMeal {
  id          String   @id @default(cuid())
  householdId String
  date        DateTime @db.Date
  slot        MealSlot
  recipeId    String
  createdById String?
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipe    Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdBy Sim?      @relation("PlannedMealCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([householdId, date, slot])
  @@index([householdId, date])
}
