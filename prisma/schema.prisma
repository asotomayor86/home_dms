// Prisma schema — HOME DMS
// Incremento 1: gestión de usuarios (sims), hogares y pertenencias.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Nombres de variable que crea la integración Neon ↔ Vercel:
  //   POSTGRES_PRISMA_URL      → conexión con pooling (runtime serverless)
  //   POSTGRES_URL_NON_POOLING → conexión directa (migraciones)
  // En local apunta ambas a tu cadena de conexión (ver .env.example).
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum GlobalRole {
  ADMIN
  USER
}

/// Un "sim" es una cuenta de persona dentro de la app (no hay email en ningún sitio).
model Sim {
  id                 String       @id @default(cuid())
  username           String       @unique
  passwordHash       String
  displayName        String
  avatar             String?
  globalRole         GlobalRole   @default(USER)
  mustChangePassword Boolean      @default(true)
  createdAt          DateTime     @default(now())

  memberships        Membership[]
}

/// Un hogar al que pertenecen uno o varios sims.
model Household {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())

  memberships Membership[]
}

/// Relación N:M entre Sim y Household. Sin rol dentro del hogar.
model Membership {
  simId       String
  householdId String
  joinedAt    DateTime  @default(now())

  sim         Sim       @relation(fields: [simId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@id([simId, householdId])
}
